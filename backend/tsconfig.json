{
  "compilerOptions": {
    "target": "ES2020",

    "module": "Node16",
    "moduleResolution": "node16",

    "typeRoots": [
      "./src/@types",
      "./node_modules/@types"
    ],

    "rootDir": "./src",
    "outDir": "./dist",

    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true
  },

  "include": ["src"]
}